# Skip Puppeteer/Chromium native downloads (not needed for WhatsApp bot)
PUPPETEER_SKIP_DOWNLOAD=true
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# Suppress audit warnings during Docker build — vulnerabilities are known
# (ytdl-core is effectively abandoned upstream; replace with @distube/ytdl-core
#  when you get a chance but it does not affect runtime security here)
audit=false
fund=false
update-notifier=false
