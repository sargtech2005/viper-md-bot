# ══════════════════════════════════════════════
#  VIPER BOT MD — Web Platform Config
#  Copy this to .env and fill in your values
# ══════════════════════════════════════════════

# PostgreSQL connection (fly.io sets DATABASE_URL automatically)
# For Render: copy the Internal Connection URL from your Postgres service
DATABASE_URL=postgresql://user:password@localhost:5432/viperbot

# JWT secret — generate a random string (e.g. openssl rand -hex 32)
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars

# Server port (fly.io and Render use 3000 or 8080)
PORT=3000

# Environment
NODE_ENV=production

# Free coins given to new users on signup
SIGNUP_COINS=50

# Coins cost per session creation
SESSION_COST=10

# Admin email — this account gets admin access automatically
ADMIN_EMAIL=your@email.com

# (Optional) Your WhatsApp owner numbers for the bots
OWNER_NUMBER=2348083086811
